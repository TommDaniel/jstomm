# ─── Deployment env for docker-compose.prod.yml ─────────────────────────────
# Copy to .env.prod on the VPS and fill in real secrets.
# Usage: docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build

# ── App (Laravel) ──
APP_NAME="70 Anos da Vó"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://jstomm.com

LOG_CHANNEL=stderr
LOG_LEVEL=warning

# ── Database ──
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=vo_app
DB_USERNAME=vo_user
DB_PASSWORD=CHANGE_ME_strong_random_password

# ── Sessions / Cookies ──
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_DOMAIN=.jstomm.com
QUEUE_CONNECTION=database

# ── Classifier (CLIP service interno) ──
CLASSIFIER_URL=http://classifier:8000

# ── MinIO (internal only, never exposed to the internet) ──
MINIO_ROOT_USER=CHANGE_ME_minio_user
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password

FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=${MINIO_ROOT_USER}
AWS_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=vo-fotos
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# ── Sanctum / Trusted proxies ──
SANCTUM_STATEFUL_DOMAINS=jstomm.com,www.jstomm.com
TRUSTED_PROXIES=*

# ── Mail (Resend) ──
# Verificar dominio jstomm.com no Resend (DNS via Cloudflare) antes de usar
# MAIL_FROM_ADDRESS=vo@jstomm.com. Enquanto pendente, use onboarding@resend.dev
# e envie apenas pro email dono da conta Resend.
MAIL_MAILER=resend
MAIL_FROM_ADDRESS=vo@jstomm.com
MAIL_FROM_NAME="Vó Jacinta"
RESEND_KEY=re_REPLACE_WITH_YOUR_RESEND_API_KEY

# ── Daily rental digest ──
RENTALS_DIGEST_EMAIL=jstomm@hotmail.com.br

# ── Build args ──
# Get yours at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=pk.REPLACE_WITH_YOUR_TOKEN

# ── Host paths ──
# Where the Cloudflare Origin Certificate (origin.pem + origin.key) lives on the VPS.
CERTS_DIR=/opt/vo-70-anos/certs

# ── Boot behavior ──
MIGRATE_ON_BOOT=true
