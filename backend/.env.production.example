# Reference of Laravel-facing env vars for production.
# In the VPS deploy, these values are loaded by docker-compose via the
# root .env.prod file (env_file: .env.prod in docker-compose.prod.yml),
# not from a backend/.env file. This file exists for documentation.

APP_NAME="70 Anos da Vó"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://jstomm.com

LOG_CHANNEL=stderr
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=vo_app
DB_USERNAME=vo_user
DB_PASSWORD=__CHANGE_ME__

CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_DOMAIN=.jstomm.com

QUEUE_CONNECTION=sync

# MinIO (internal, no port exposed to the internet)
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=__MINIO_USER__
AWS_SECRET_ACCESS_KEY=__MINIO_PASSWORD__
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=vo-fotos
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

SANCTUM_STATEFUL_DOMAINS=jstomm.com,www.jstomm.com

# Trust Cloudflare proxy headers (Laravel TrustProxies middleware must use *)
TRUSTED_PROXIES=*

# ── Email (Resend) ──
# Depois de verificar jstomm.com no Resend, MAIL_FROM_ADDRESS=vo@jstomm.com.
# Enquanto o dominio nao esta verificado, use 'onboarding@resend.dev' e mande
# apenas pro email do owner da conta Resend.
MAIL_MAILER=resend
MAIL_FROM_ADDRESS=vo@jstomm.com
MAIL_FROM_NAME="Vó Jacinta"
RESEND_KEY=re_REPLACE_WITH_YOUR_RESEND_API_KEY

# ── Daily rental digest ──
# Destino do email diario de locacoes (8h timezone America/Sao_Paulo).
RENTALS_DIGEST_EMAIL=jstomm@hotmail.com.br

MIGRATE_ON_BOOT=true
