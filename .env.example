# Application
APP_NAME="70 Anos da Vó"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Database (PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=vo_app
DB_USERNAME=vo_user
DB_PASSWORD=vo_secret

# Cache & Session
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# Storage (MinIO in dev, filesystem in prod)
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=minio_user
AWS_SECRET_ACCESS_KEY=minio_secret
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=vo-fotos
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# MinIO (development only)
MINIO_ROOT_USER=minio_user
MINIO_ROOT_PASSWORD=minio_secret

# Mapbox (create free account at mapbox.com)
VITE_MAPBOX_TOKEN=

# Auth
SANCTUM_STATEFUL_DOMAINS=localhost

# Mail (not required for this app)
MAIL_MAILER=log
